{
  "name": "dln-lite-logistics-network",
  "version": "1.0.0",
  "client": {
    "organization": "Shipper",
    "connection": {
      "timeout": {
        "peer": { "endorser": "300" },
        "orderer": "300"
      }
    }
  },
  "organizations": {
    "Shipper": {
      "mspid": "ShipperMSP",
      "peers": ["peer0.shipper.dln.com"],
      "certificateAuthorities": ["ca.shipper.dln.com"],
      "adminPrivateKey": {
        "path": "crypto-config/peerOrganizations/shipper.dln.com/users/Admin@shipper.dln.com/msp/keystore/priv_sk"
      },
      "signedCert": {
        "path": "crypto-config/peerOrganizations/shipper.dln.com/users/Admin@shipper.dln.com/msp/signcerts/Admin@shipper.dln.com-cert.pem"
      }
    },
    "Carrier": {
      "mspid": "CarrierMSP",
      "peers": ["peer0.carrier.dln.com"],
      "certificateAuthorities": ["ca.carrier.dln.com"]
    },
    "Customs": {
      "mspid": "CustomsMSP",
      "peers": ["peer0.customs.dln.com"],
      "certificateAuthorities": ["ca.customs.dln.com"]
    }
  },
  "peers": {
    "peer0.shipper.dln.com": {
      "url": "grpcs://localhost:7051",
      "tlsCACerts": {
        "path": "crypto-config/peerOrganizations/shipper.dln.com/peers/peer0.shipper.dln.com/tls/ca.crt"
      },
      "grpcOptions": {
        "ssl-target-name-override": "peer0.shipper.dln.com",
        "hostnameOverride": "peer0.shipper.dln.com"
      }
    },
    "peer0.carrier.dln.com": {
      "url": "grpcs://localhost:9051",
      "tlsCACerts": {
        "path": "crypto-config/peerOrganizations/carrier.dln.com/peers/peer0.carrier.dln.com/tls/ca.crt"
      },
      "grpcOptions": {
        "ssl-target-name-override": "peer0.carrier.dln.com",
        "hostnameOverride": "peer0.carrier.dln.com"
      }
    },
    "peer0.customs.dln.com": {
      "url": "grpcs://localhost:11051",
      "tlsCACerts": {
        "path": "crypto-config/peerOrganizations/customs.dln.com/peers/peer0.customs.dln.com/tls/ca.crt"
      },
      "grpcOptions": {
        "ssl-target-name-override": "peer0.customs.dln.com",
        "hostnameOverride": "peer0.customs.dln.com"
      }
    }
  },
  "orderers": {
    "orderer.dln.com": {
      "url": "grpcs://localhost:7050",
      "tlsCACerts": {
        "path": "crypto-config/ordererOrganizations/dln.com/orderers/orderer.dln.com/msp/tlscacerts/tlsca.dln.com-cert.pem"
      },
      "grpcOptions": {
        "ssl-target-name-override": "orderer.dln.com",
        "hostnameOverride": "orderer.dln.com"
      }
    }
  },
  "certificateAuthorities": {
    "ca.shipper.dln.com": {
      "url": "http://localhost:7054",
      "caName": "ca-shipper",
      "httpOptions": { "verify": false }
    },
    "ca.carrier.dln.com": {
      "url": "http://localhost:8054",
      "caName": "ca-carrier",
      "httpOptions": { "verify": false }
    },
    "ca.customs.dln.com": {
      "url": "http://localhost:10054",
      "caName": "ca-customs",
      "httpOptions": { "verify": false }
    }
  },
  "channels": {
    "dlnchannel": {
      "orderers": ["orderer.dln.com"],
      "peers": {
        "peer0.shipper.dln.com": {
          "endorsingPeer": true,
          "chaincodeQuery": true,
          "ledgerQuery": true,
          "eventSource": true
        },
        "peer0.carrier.dln.com": {
          "endorsingPeer": true,
          "chaincodeQuery": true,
          "ledgerQuery": true,
          "eventSource": true
        },
        "peer0.customs.dln.com": {
          "endorsingPeer": true,
          "chaincodeQuery": true,
          "ledgerQuery": true,
          "eventSource": true
        }
      }
    }
  }
}
