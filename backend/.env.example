NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://admin:dlnpassword@localhost:27017/dlnlite?authSource=admin

# ML Service
ML_SERVICE_URL=http://localhost:5000

# Fabric
FABRIC_CHANNEL=dlnchannel
FABRIC_CHAINCODE=shipment
FABRIC_CONNECTION_PROFILE=../blockchain/network/connection-profile.json
FABRIC_CRYPTO_CONFIG_PATH=../blockchain/network/crypto-config
# Use local when backend runs on your host. Use docker when backend runs inside docker-compose.
FABRIC_NETWORK_MODE=local

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

LOG_LEVEL=info
